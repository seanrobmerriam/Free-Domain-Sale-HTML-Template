# Neon Postgres connection string (from neon.tech dashboard)
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: comma-separated origins allowed to POST to /api/offer (for cross-origin setups)
# ALLOWED_ORIGINS=https://mydomain.com,https://seconddomain.com

# Admin dashboard at /admin
ADMIN_PASSWORD=change-me-to-something-strong
